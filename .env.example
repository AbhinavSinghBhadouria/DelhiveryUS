# Backend
NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://postgres:postgres@localhost:55432/delhiveryus_lastmile
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:5173

# Frontend (copy to frontend/.env)
VITE_API_BASE_URL=http://localhost:5000/api

# Email — mock logs to DB; set resend + API key for real email
EMAIL_PROVIDER=mock
EMAIL_API_KEY=replace_with_email_api_key
EMAIL_FROM=no-reply@example.com

# SMS — mock logs to DB; set twilio credentials for real SMS
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_FROM_NUMBER=replace_with_twilio_number

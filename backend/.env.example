# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5001

# ─── Database ─────────────────────────────────────────────
# Local Docker:
# DATABASE_URL=postgresql://postgres:postgres@localhost:55432/delhiveryus_lastmile
# Neon (production):
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxxx.neon.tech/neondb?sslmode=require

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Email (Nodemailer via Gmail SMTP) ────────────────────
# EMAIL_PROVIDER options: nodemailer | mock
EMAIL_PROVIDER=nodemailer
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
EMAIL_FROM=your-gmail@gmail.com

# ─── SMS (optional — leave as mock if not using Twilio) ───
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=replace_with_twilio_account_sid
TWILIO_AUTH_TOKEN=replace_with_twilio_auth_token
TWILIO_FROM_NUMBER=replace_with_twilio_number
